# Quick start (zero-config): do not set DATABASE_URL or OPENAI_API_KEY.
# Defaults:
# - AI_MODE=mock
# - SQLite file at ./local.db

AI_MODE=mock

# Optional: custom SQLite path when DATABASE_URL is not set.
# SQLITE_PATH=./local.db

# Optional: Advanced mode (real model)
# AI_MODE=real
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Optional: Advanced mode (Postgres)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_infra
