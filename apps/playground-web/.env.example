# playground-web is the durable runtime console reference consumer.

# runtime-pi server route configuration:
# If both are present, runtime-pi defaults to DeepSeek and exposes both model families in the UI.
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# db configuration:
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=...
# DATABASE_URL=postgres://...
# SQLITE_PATH=./local.db
