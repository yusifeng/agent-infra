# playground-web is primarily an experiment harness.
# `/` stays browser-local, while `/runtime-pi` exercises the durable server-side runtime adapter.

# Optional: pi-narrow (DEV ONLY) preload DeepSeek key into browser storage.
# This will expose the key to the browser when PI_NARROW_ALLOW_ENV_KEYS=1.
# PI_NARROW_ALLOW_ENV_KEYS=0
# DEEPSEEK_API_KEY=sk-...

# runtime-pi server route configuration:
# If both are present, runtime-pi defaults to DeepSeek and exposes both model families in the UI.
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
